# ============================================================================
# FINBERG MARKETS — Environment Configuration Template
# Copy to .env.local and fill in. NEVER commit real secrets.
# ============================================================================

# ----- Runtime -----
NODE_ENV=development
LOG_LEVEL=info

# ----- Public URLs -----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Database -----
DATABASE_URL=postgresql://finberg:finberg@localhost:5432/finberg
TIMESCALE_URL=postgresql://finberg:finberg@localhost:5433/finberg_ts
REDIS_URL=redis://localhost:6379
CLICKHOUSE_URL=http://localhost:8123

# ----- Streaming -----
KAFKA_BROKERS=localhost:9092
NATS_URL=nats://localhost:4222

# ----- Object storage (S3 / MinIO) -----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=finberg-charts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ----- Auth (JWT) -----
JWT_ISSUER=https://auth.finberg.markets
JWT_AUDIENCE=finberg-api
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
JWT_ACCESS_TTL=300
JWT_REFRESH_TTL=2592000

# ----- OAuth providers -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ----- Market data providers -----
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
TRADING_ECONOMICS_API_KEY=
COINGECKO_API_KEY=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ----- AI -----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ANALYSIS=claude-opus-4-8
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# ----- Payments -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
COINBASE_COMMERCE_API_KEY=

# ----- Notifications -----
SES_REGION=eu-central-1
SES_FROM_ADDRESS=alerts@finberg.markets
TELEGRAM_BOT_TOKEN=
FCM_SERVICE_ACCOUNT_PATH=./secrets/fcm.json
APNS_KEY_PATH=./secrets/apns.p8
APNS_KEY_ID=
APNS_TEAM_ID=

# ----- Observability -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

# ----- Feature flags -----
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=
