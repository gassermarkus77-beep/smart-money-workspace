{
  "expo": {
    "name": "FINBERG MARKETS",
    "slug": "finberg-markets",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "finberg",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f17"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "markets.finberg.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to securely access your FINBERG account."
      }
    },
    "android": {
      "package": "markets.finberg.app",
      "versionCode": 1,
      "permissions": ["INTERNET", "USE_BIOMETRIC", "USE_FINGERPRINT"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f17"
      }
    },
    "newArchEnabled": true,
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication"
    ]
  }
}
